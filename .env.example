# Backend only
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1
SUPABASE_URL=
SUPABASE_SECRET_KEY=
API_HOST=127.0.0.1
API_PORT=3002
WEB_ORIGIN=http://127.0.0.1:3001
TTS_SERVICE_URL=http://127.0.0.1:8000
CHAT_MAX_CONTEXT_MESSAGES=20
CHAT_RATE_LIMIT_PER_MINUTE=20

# TTS service
TTS_HOST=127.0.0.1
TTS_PORT=8000
TTS_VOICE=Trúc Ly
TTS_STYLE=tu_nhien
TTS_MAX_TEXT_LENGTH=600
TTS_CACHE_DIR=./cache
TTS_CACHE_MAX_FILES=200
TTS_STREAM_CHUNK_FRAMES=1

# Frontend-safe variables only
VITE_API_BASE_URL=http://127.0.0.1:3002
VITE_ENABLE_PERF_METRICS=false

# Memory config
MEMORY_ENABLED=true
MEMORY_RECENT_MESSAGE_LIMIT=24
MEMORY_TOP_K=8
MEMORY_SUMMARY_TRIGGER_MESSAGES=20
MEMORY_SUMMARY_MAX_CHARS=4000
MEMORY_MAX_CONTEXT_TOKENS=6000
MEMORY_RETENTION_DAYS=0
MEMORY_RETRIEVAL_TIMEOUT_MS=700
MEMORY_EMBEDDINGS_ENABLED=false
MISTRAL_EMBEDDING_MODEL=
